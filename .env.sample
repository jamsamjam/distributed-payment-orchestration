# ==============================
# Database
# ==============================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dpo
POSTGRES_USER=dpo
POSTGRES_PASSWORD=dpo
DATABASE_URL=postgresql://dpo:v@postgres:5432/dpo

# ==============================
# Redis
# ==============================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ==============================
# API Gateway
# ==============================
GATEWAY_PORT=3000
GATEWAY_API_KEY=dev-api-key-12345
RATE_LIMIT_MAX_TOKENS=100
RATE_LIMIT_REFILL_RATE=100

# ==============================
# Payment Orchestrator
# ==============================
ORCHESTRATOR_HOST=payment-orchestrator
ORCHESTRATOR_PORT=8080
FRAUD_BLOCK_THRESHOLD=80
FRAUD_FLAG_THRESHOLD=50

# ==============================
# Fraud Engine
# ==============================
FRAUD_ENGINE_HOST=fraud-engine
FRAUD_ENGINE_PORT=8000

# ==============================
# Provider Router
# ==============================
PROVIDER_ROUTER_HOST=provider-router
PROVIDER_ROUTER_PORT=8081

# ==============================
# Ledger Service
# ==============================
LEDGER_HOST=ledger-service
LEDGER_PORT=8082

# ==============================
# Provider Mock
# ==============================
PROVIDER_MOCK_HOST=provider-mock
PROVIDER_MOCK_PORT=9000

# Stripe mock config
STRIPE_SUCCESS_RATE=0.98
STRIPE_MIN_LATENCY_MS=80
STRIPE_MAX_LATENCY_MS=200

# Adyen mock config
ADYEN_SUCCESS_RATE=0.96
ADYEN_MIN_LATENCY_MS=100
ADYEN_MAX_LATENCY_MS=300

# paypal mock config
PAYPAL_SUCCESS_RATE=0.94
PAYPAL_MIN_LATENCY_MS=150
PAYPAL_MAX_LATENCY_MS=400

# ==============================
# Analytics Worker
# ==============================
ANALYTICS_WORKER_PORT=3002
METRICS_WINDOW_SECONDS=60
METRICS_PUBLISH_INTERVAL_MS=5000

# ==============================
# Web UI
# ==============================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SSE_URL=http://localhost:3000/stream/transactions
